// Kairox - AI Trading Signal Application
// Database Schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Authentication & Users ─────────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  passwordHash  String?
  name          String?
  role          UserRole  @default(VIEWER)
  image         String?
  emailVerified DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts   Account[]
  sessions   Session[]
  watchlists Watchlist[]
  auditLogs  AuditLog[]
}

enum UserRole {
  ADMIN
  ANALYST
  TRADER
  VIEWER
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── Assets & Market Data ───────────────────────────────────────────────────

model Asset {
  id        String        @id @default(cuid())
  symbol    String        @unique
  name      String
  category  AssetCategory
  isActive  Boolean       @default(true)
  createdAt DateTime      @default(now())

  signals    Signal[]
  snapshots  MarketSnapshot[]
  watchlists WatchlistAsset[]
}

enum AssetCategory {
  CRYPTO
  FOREX
  COMMODITY
  INDEX
}

model MarketSnapshot {
  id         String   @id @default(cuid())
  assetId    String
  timeframe  String
  candles    Json
  indicators Json
  metadata   Json?
  createdAt  DateTime @default(now())

  asset Asset @relation(fields: [assetId], references: [id])

  @@index([assetId, timeframe, createdAt])
}

// ─── Signals ────────────────────────────────────────────────────────────────

model Signal {
  id              String       @id @default(cuid())
  assetId         String
  timeframe       String
  side            SignalSide
  confidence      Float
  entry           Decimal      @db.Decimal(20, 8)
  stopLoss        Decimal      @db.Decimal(20, 8)
  targets         Json
  invalidation    String?
  reasoning       String       @db.Text
  keyFactors      Json?
  promptVersionId String?
  snapshotId      String?
  status          SignalStatus @default(PENDING)
  createdAt       DateTime     @default(now())
  expiresAt       DateTime?

  asset          Asset           @relation(fields: [assetId], references: [id])
  promptVersion  PromptVersion?  @relation(fields: [promptVersionId], references: [id])
  riskAssessment RiskAssessment?
  votes          SignalVote[]
  paperOrders    PaperOrder[]

  @@index([assetId, status, createdAt])
  @@index([status, createdAt])
}

enum SignalSide {
  LONG
  SHORT
  HOLD
}

enum SignalStatus {
  PENDING
  APPROVED
  BLOCKED
  EXPIRED
  INVALIDATED
}

model SignalVote {
  id          String     @id @default(cuid())
  signalId    String
  modelId     String
  apiProvider String
  role        VoteRole
  side        SignalSide
  confidence  Float
  reasoning   String     @db.Text
  rawResponse Json
  latencyMs   Int
  tokenUsage  Json
  createdAt   DateTime   @default(now())

  signal Signal @relation(fields: [signalId], references: [id], onDelete: Cascade)

  @@index([signalId])
}

enum VoteRole {
  PRIMARY
  CONFIRMATION
  RISK_REVIEW
}

// ─── Risk Management ────────────────────────────────────────────────────────

model RiskAssessment {
  id              String      @id @default(cuid())
  signalId        String      @unique
  positionSize    Decimal     @db.Decimal(20, 8)
  riskPercent     Float
  rewardToRisk    Float
  maxDrawdown     Float?
  exposureCheck   Boolean
  correlationFlag Boolean     @default(false)
  verdict         RiskVerdict
  reasons         Json
  createdAt       DateTime    @default(now())

  signal Signal @relation(fields: [signalId], references: [id], onDelete: Cascade)
}

enum RiskVerdict {
  APPROVED
  REDUCED
  WATCH_ONLY
  BLOCKED
}

// ─── Paper Trading ──────────────────────────────────────────────────────────

model PaperOrder {
  id         String      @id @default(cuid())
  signalId   String
  side       SignalSide
  entryPrice Decimal     @db.Decimal(20, 8)
  exitPrice  Decimal?    @db.Decimal(20, 8)
  stopLoss   Decimal     @db.Decimal(20, 8)
  quantity   Decimal     @db.Decimal(20, 8)
  status     OrderStatus @default(OPEN)
  pnl        Decimal?    @db.Decimal(20, 8)
  openedAt   DateTime    @default(now())
  closedAt   DateTime?

  signal Signal @relation(fields: [signalId], references: [id])

  @@index([status])
}

enum OrderStatus {
  OPEN
  CLOSED
  STOPPED
  CANCELLED
}

// ─── Prompts & Model Configuration ──────────────────────────────────────────

model PromptVersion {
  id        String   @id @default(cuid())
  name      String
  template  String   @db.Text
  version   Int
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  signals Signal[]

  @@unique([name, version])
}

model ModelConfig {
  id         String   @id @default(cuid())
  modelId    String
  apiProvider String  @default("openrouter")
  role       VoteRole
  isActive   Boolean  @default(true)
  parameters Json
  priority   Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

// ─── Strategy & Policies ────────────────────────────────────────────────────

model StrategyPolicy {
  id                 String  @id @default(cuid())
  name               String  @unique
  maxRiskPercent     Float   @default(2.0)
  maxOpenTrades      Int     @default(5)
  maxCorrelated      Int     @default(3)
  minRewardRisk      Float   @default(1.5)
  dailyDrawdownLimit Float   @default(5.0)
  cooldownMinutes    Int     @default(60)
  isActive           Boolean @default(true)
}

// ─── Watchlists ─────────────────────────────────────────────────────────────

model Watchlist {
  id        String           @id @default(cuid())
  userId    String
  name      String
  createdAt DateTime         @default(now())

  user   User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  assets WatchlistAsset[]
}

model WatchlistAsset {
  id          String @id @default(cuid())
  watchlistId String
  assetId     String

  watchlist Watchlist @relation(fields: [watchlistId], references: [id], onDelete: Cascade)
  asset     Asset    @relation(fields: [assetId], references: [id])

  @@unique([watchlistId, assetId])
}

// ─── Backtesting ────────────────────────────────────────────────────────────

model BacktestRun {
  id              String   @id @default(cuid())
  assetId         String
  timeframe       String
  startDate       DateTime
  endDate         DateTime
  promptVersionId String?
  modelConfig     Json
  results         Json
  trades          Json
  createdAt       DateTime @default(now())
}

// ─── Audit & Observability ──────────────────────────────────────────────────

model AuditLog {
  id        String   @id @default(cuid())
  userId    String?
  action    String
  entity    String
  entityId  String?
  details   Json?
  ip        String?
  createdAt DateTime @default(now())

  user User? @relation(fields: [userId], references: [id])

  @@index([entity, entityId])
  @@index([userId, createdAt])
}
